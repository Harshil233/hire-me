# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database
# Transactions (HR registration) require a replica set — docker-compose starts
# MongoDB as a single-node replica set named rs0.
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGO_DB_NAME=hire_me

# ---------------------------------------------------------------------------
# Authentication — generate real secrets before deploying anywhere
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
RATE_LIMIT_WINDOW_MS=900000
# ~100 requests a minute: one page of a browsing session is a dozen calls, and the
# limit is per IP, so a shared office address spends this budget between everyone.
RATE_LIMIT_MAX=1500
AUTH_RATE_LIMIT_MAX=10

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
FILE_STORAGE_DRIVER=local
FILE_STORAGE_PATH=./uploads
MAX_UPLOAD_BYTES=5242880

# ---------------------------------------------------------------------------
# Outreach email
# ---------------------------------------------------------------------------
# Every setting in this block has a working default, so the whole section can be left
# out of a local `.env`. Fill it in when you are ready to send for real.
#
# `log` writes the message to the log instead of sending it — the default, so the app
# runs without an API key. Switch to `resend` and fill the key to send for real.
MAIL_DRIVER=log
RESEND_API_KEY=
# Must be an address Resend has verified for your account. `onboarding@resend.dev`
# works without a verified domain, but only delivers to your own account address.
MAIL_FROM_EMAIL=onboarding@resend.dev
MAIL_FROM_NAME=Hire Me
# Until a sending domain is verified, Resend only accepts mail to your own account
# address. Put it here and every outreach email is redirected there for testing, with
# the intended recipient shown in the subject. Leave empty to deliver for real.
MAIL_REDIRECT_TO=
APP_BASE_URL=http://localhost:5173
# Signs the unsubscribe links. The default is public and refused in production.
UNSUBSCRIBE_SECRET=change-me-unsubscribe-secret-at-least-32-characters
OUTREACH_MAX_RECIPIENTS=200
OUTREACH_DAILY_LIMIT=500
