# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database
# Transactions (HR registration) require a replica set — docker-compose starts
# MongoDB as a single-node replica set named rs0.
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGO_DB_NAME=hire_me

# ---------------------------------------------------------------------------
# Authentication — generate real secrets before deploying anywhere
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
FILE_STORAGE_DRIVER=local
FILE_STORAGE_PATH=./uploads
MAX_UPLOAD_BYTES=5242880
