# ---------------------------------------------------------------------------
# Root environment — read by `docker compose` only.
#
# NOTHING HERE IS REQUIRED. `docker compose up --build` works with this file
# absent: every variable below has a development fallback baked into
# docker-compose.yml. Copy it to `.env` only when you want to override one.
#
#   cp .env.example .env
#
# The per-application variables live in `backend/.env.example` and
# `frontend/.env.example`; those are for running an app outside Docker.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Secrets
#
# The compose defaults are published in this repository, which makes them
# public knowledge and therefore not secrets at all. That is acceptable on a
# laptop and unacceptable anywhere reachable. Generate real ones with:
#
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
# Minimum 32 characters each — the API refuses to boot below that.
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Signs unsubscribe links. Without a real value anyone could forge one for any
# address, so the API refuses to boot in production while it is the default.
UNSUBSCRIBE_SECRET=

# ---------------------------------------------------------------------------
# Outreach email
#
# `log` (the default) writes each message to the container log instead of
# sending it, so the feature is fully explorable with no account anywhere.
# Switch to `resend` and supply a key to send for real.
# ---------------------------------------------------------------------------
MAIL_DRIVER=log
RESEND_API_KEY=
MAIL_FROM_EMAIL=onboarding@resend.dev

# Sends every outreach email here instead of its real recipient. Useful before a
# sending domain is verified, when a provider will only accept mail addressed to
# the account's own address.
MAIL_REDIRECT_TO=
